@page "/reviews/create/{RevieweeId}"

@using Microsoft.AspNetCore.Identity
@using SomaShare.Models
@using SomaShare.Services

@inject IReviewService ReviewService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<h3>Leave Review</h3>

<div class="card p-3">

    <div class="mb-3">
        <label>Rating (1 - 5)</label>
        <InputNumber @bind-Value="Rating"
                     class="form-control" />
    </div>

    <div class="mb-3">
        <label>Comment</label>
        <InputTextArea @bind-Value="Comment"
                       class="form-control" />
    </div>

    <button class="btn btn-primary"
            @onclick="SubmitReview">

        Submit Review

    </button>

</div>

@code {

    [Parameter]
    public string RevieweeId { get; set; }

    private int Rating = 5;
    private string Comment = string.Empty;

    private async Task SubmitReview()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var user =
            await UserManager.GetUserAsync(authState.User);

        if (user == null)
            return;

        var review = new Review
        {
            Rating = Rating,
            Comment = Comment,
            DatePosted = DateTime.Now,
            ReviewerId = user.Id,
            RevieweeId = RevieweeId
        };

        await ReviewService.AddReviewAsync(review);

        Navigation.NavigateTo("/reviews/myreviews");
    }
}