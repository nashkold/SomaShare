@page "/offers/myoffers"

@using Microsoft.AspNetCore.Identity
@using SomaShare.Models
@using SomaShare.Services

@inject IOfferService OfferService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<h3>My Offers</h3>

@if (!offers.Any())
{
    <p>No offers found.</p>
}
else
{
    <table class="table">

        <thead>
            <tr>
                <th>Book</th>
                <th>Offer</th>
                <th>Status</th>
                <th>Date</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var offer in offers)
            {
                <tr>
                    <td>@offer.Textbook?.Title</td>
                    <td>R @offer.OfferAmount</td>
                    <td>@offer.Status</td>
                    <td>@offer.DateMade.ToShortDateString()</td>
                </tr>
            }
        </tbody>

    </table>
}

@code {

    private List<Offer> offers = new();

    protected override async Task OnInitializedAsync()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var user =
            await UserManager.GetUserAsync(authState.User);

        if (user == null)
            return;

        offers =
            await OfferService.GetOffersByBuyerAsync(user.Id);
    }
}