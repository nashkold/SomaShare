@page "/wishlist"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using SomaShare.Models
@using SomaShare.Services
@inject IFavouriteService FavouriteService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@attribute [Authorize]

<div class="container mt-4 pb-5">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h1 class="h3 mb-0">❤️ My Wishlist</h1>
            <p class="text-muted small mb-0">Books you've saved — @favourites.Count item@(favourites.Count == 1 ? "" : "s")</p>
        </div>
        <a href="/textbooks" class="btn btn-primary">
            Browse More Books
        </a>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @statusClass alert-dismissible d-flex align-items-center gap-2 mb-4"
             role="alert" aria-live="polite">
            <span>@statusMessage</span>
            <button type="button" class="btn-close ms-auto"
                    @onclick="() => statusMessage = string.Empty"
                    aria-label="Dismiss"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5" role="status" aria-live="polite">
            <div class="spinner-border text-danger" aria-hidden="true"></div>
            <p class="mt-2 text-muted">Loading your wishlist…</p>
        </div>
    }

    else if (!favourites.Any())
    {
        <div class="text-center py-5">
            <div class="display-1 mb-3" aria-hidden="true">🔖</div>
            <h4 class="text-muted">Your wishlist is empty</h4>
            <p class="text-muted mb-4">
                Browse the listings and click <strong>❤️ Save</strong> on any book to add it here.
            </p>
            <a href="/textbooks" class="btn btn-primary btn-lg">Browse Textbooks</a>
        </div>
    }

    else
    {
        <div class="row g-4" role="list" aria-label="Saved textbooks">
            @foreach (var fav in favourites)
            {
                var book = fav.Textbook;
                if (book == null) continue;

                <div class="col-sm-6 col-lg-4" role="listitem">
                    <article class="card h-100 shadow-sm wishlist-card"
                             aria-label="@book.Title by @book.Author">

                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                        {
                            <img src="@book.ImageUrl"
                                 class="card-img-top"
                                 style="height:180px;object-fit:cover;"
                                 alt="Cover of @book.Title" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center"
                                 style="height:180px;font-size:3.5rem;"
                                 aria-hidden="true">
                                📖
                            </div>
                        }

                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title fw-bold mb-1">@book.Title</h5>
                            <p class="text-muted small mb-2">
                                by <em>@(book.Author ?? "Unknown author")</em>
                            </p>

                            <div class="mb-3 d-flex flex-wrap gap-1">
                                @if (!string.IsNullOrEmpty(book.Condition))
                                {
                                    <span class="badge bg-secondary">@book.Condition</span>
                                }
                                @if (!string.IsNullOrEmpty(book.Campus))
                                {
                                    <span class="badge bg-info text-dark">@book.Campus</span>
                                }
                                @if (book.IsAvailable)
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Sold</span>
                                }
                            </div>

                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-baseline mb-3">
                                    <span class="fs-5 fw-bold text-success">
                                        R @book.Price.ToString("0.00")
                                    </span>
                                    <span class="text-muted small">
                                        @(book.Seller?.FullName ?? "Unknown seller")
                                    </span>
                                </div>

                                <div class="d-flex gap-2">
                                    @if (book.IsAvailable)
                                    {
                                        <a href="/offers/make/@book.TextbookId"
                                           class="btn btn-success btn-sm flex-grow-1"
                                           aria-label="Make an offer on @book.Title">
                                            🤝 Make Offer
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-secondary btn-sm flex-grow-1" disabled
                                                aria-label="@book.Title is no longer available">
                                            Sold
                                        </button>
                                    }

                                    <button class="btn btn-outline-danger btn-sm"
                                            @onclick="() => RemoveFavourite(fav.FavouriteId, book.TextbookId, book.Title)"
                                            disabled="@removingIds.Contains(fav.FavouriteId)"
                                            aria-label="Remove @book.Title from wishlist"
                                            title="Remove from wishlist">
                                        @if (removingIds.Contains(fav.FavouriteId))
                                        {
                                            <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                                        }
                                        else
                                        {
                                            <span aria-hidden="true">🗑️</span>
                                        }
                                    </button>
                                </div>
                            </div>

                        </div>
                    </article>
                </div>
            }
        </div>

        @if (favourites.Count > 1)
        {
            <div class="text-end mt-4">
                @if (confirmClearAll)
                {
                    <span class="text-muted me-2 small">Remove all @favourites.Count saved books?</span>
                    <button class="btn btn-danger btn-sm me-2" @onclick="ClearAll"
                            aria-label="Confirm remove all from wishlist">
                        Yes, clear all
                    </button>
                    <button class="btn btn-outline-secondary btn-sm"
                            @onclick="() => confirmClearAll = false"
                            aria-label="Cancel clear all">
                        Cancel
                    </button>
                }
                else
                {
                    <button class="btn btn-outline-danger btn-sm"
                            @onclick="() => confirmClearAll = true"
                            aria-label="Remove all books from wishlist">
                        🗑️ Clear Wishlist
                    </button>
                }
            </div>
        }
    }

</div>

@code {

    private List<Favourite> favourites = new();
    private HashSet<int> removingIds = new();   // tracks in-progress removals per card
    private string currentUserId = string.Empty;
    private bool isLoading = true;
    private bool confirmClearAll = false;
    private string statusMessage = string.Empty;
    private string statusClass = "alert-success";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user == null)
        {
            NavigationManager.NavigateTo("/account/login", forceLoad: true);
            return;
        }

        currentUserId = user.Id;
        await LoadFavourites();
        isLoading = false;
    }

    private async Task LoadFavourites()
    {
        favourites = await FavouriteService.GetUserFavouritesAsync(currentUserId);
    }

    private async Task RemoveFavourite(int favouriteId, int textbookId, string title)
    {
        removingIds.Add(favouriteId);
        try
        {
            await FavouriteService.RemoveFavouriteAsync(currentUserId, textbookId);
            await LoadFavourites();
            ShowStatus($"{ title}removed from your wishlist.", "alert-success");
        }
        catch (Exception ex)
        {
            ShowStatus($"Error removing book: {ex.Message}", "alert-danger");
        }
        finally
        {
            removingIds.Remove(favouriteId);
            confirmClearAll = false;
        }
    }

    private async Task ClearAll()
    {
        try
        {
            // Remove each favourite sequentially using the service
            foreach (var fav in favourites.ToList())
            {
                await FavouriteService.RemoveFavouriteAsync(currentUserId, fav.TextbookId);
            }
            await LoadFavourites();
            ShowStatus("Wishlist cleared.", "alert-success");
        }
        catch (Exception ex)
        {
            ShowStatus($"Error clearing wishlist: {ex.Message}", "alert-danger");
        }
        finally
        {
            confirmClearAll = false;
        }
    }

    private void ShowStatus(string message, string cssClass = "alert-success")
    {
        statusMessage = message;
        statusClass = cssClass;
    }
}
