@page "/textbooks"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using SomaShare.Data
@using SomaShare.Models
@using SomaShare.Services
@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize]

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📚 Textbook Listings</h2>
        <button class="btn btn-success" @onclick="ShowCreateForm">+ List a Textbook</button>
    </div>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible">
            @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
        </div>
    }

    <div class="card mb-4 p-3">
        <div class="row g-2">
            <div class="col-md-4">
                <input class="form-control" placeholder="Search title, author, ISBN…"
                       value="@searchTerm"
                       @oninput="e => { searchTerm = e.Value?.ToString() ?? string.Empty; ApplyFilters(); }" />
            </div>
            <div class="col-md-2">
                <select class="form-select" @bind="filterCondition" @bind:after="ApplyFilters">
                    <option value="">All Conditions</option>
                    <option>New</option>
                    <option>Good</option>
                    <option>Fair</option>
                    <option>Poor</option>
                </select>
            </div>
            <div class="col-md-2">
                <input class="form-control" type="number" placeholder="Min Price (R)"
                       @bind="minPrice" @bind:after="ApplyFilters" />
            </div>
            <div class="col-md-2">
                <input class="form-control" type="number" placeholder="Max Price (R)"
                       @bind="maxPrice" @bind:after="ApplyFilters" />
            </div>
            <div class="col-md-2">
                <select class="form-select" @bind="sortBy" @bind:after="ApplyFilters">
                    <option value="date">Newest First</option>
                    <option value="price_asc">Price: Low → High</option>
                    <option value="price_desc">Price: High → Low</option>
                </select>
            </div>
        </div>
    </div>

    @if (showForm)
    {
        <div class="card mb-4 p-4 border-primary">
            <h4>@(editingId == 0 ? "List a New Textbook" : "Edit Listing")</h4>
            <EditForm Model="@formModel" OnValidSubmit="HandleSave">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Title *</label>
                        <InputText @bind-Value="formModel.Title" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Author</label>
                        <InputText @bind-Value="formModel.Author" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">ISBN</label>
                        <InputText @bind-Value="formModel.ISBN" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Condition *</label>
                        <InputSelect @bind-Value="formModel.Condition" class="form-select">
                            <option value="">-- Select --</option>
                            <option>New</option>
                            <option>Good</option>
                            <option>Fair</option>
                            <option>Poor</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Price (R) *</label>
                        <InputNumber @bind-Value="formModel.Price" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Campus</label>
                        <InputText @bind-Value="formModel.Campus" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Image URL (optional)</label>
                        <InputText @bind-Value="formModel.ImageUrl" class="form-control" />
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        @(editingId == 0 ? "Create Listing" : "Save Changes")
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
                </div>
            </EditForm>
        </div>
    }

    @if (confirmDeleteId != 0)
    {
        <div class="alert alert-warning d-flex align-items-center justify-content-between">
            <span>⚠️ Are you sure you want to delete <strong>@confirmDeleteTitle</strong>?</span>
            <div class="d-flex gap-2">
                <button class="btn btn-danger btn-sm" @onclick="ConfirmDelete">Yes, Delete</button>
                <button class="btn btn-secondary btn-sm" @onclick="() => confirmDeleteId = 0">Cancel</button>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Loading listings…</p>
        </div>
    }
    else if (!pagedListings.Any())
    {
        <div class="text-center py-5 text-muted">
            <p>No textbooks found. Be the first to list one!</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var book in pagedListings)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                        {
                            <img src="@book.ImageUrl" class="card-img-top"
                                 style="height:160px;object-fit:cover;"
                                 alt="@book.Title" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center"
                                 style="height:160px;font-size:3rem;">📖</div>
                        }
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@book.Title</h5>
                            <p class="card-text text-muted small mb-1">by @book.Author</p>
                            <p class="card-text small">
                                <span class="badge bg-secondary me-1">@book.Condition</span>
                                @if (!string.IsNullOrEmpty(book.Campus))
                                {
                                    <span class="badge bg-info text-dark">@book.Campus</span>
                                }
                            </p>
                            <p class="card-text small text-muted">ISBN: @book.ISBN</p>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-success fs-5">R @book.Price.ToString("0.00")</span>
                                <span class="small text-muted">@book.DatePosted.ToString("dd MMM yyyy")</span>
                            </div>
                            <p class="small text-muted mt-1">Seller: @(book.Seller?.FullName ?? "Unknown")</p>

                            @if (book.SellerId != currentUserId)
                            {
                                 <div class="mt-1">
                                     <FavouriteButton TextbookId="@book.TextbookId" UserId="@currentUserId" />
                                 </div>
                            }

                            @if (book.SellerId == currentUserId)
                            {
                                <div class="d-flex gap-2 mt-2">
                                    <button class="btn btn-outline-primary btn-sm w-50"
                                        @onclick="() => StartEdit(book)">Edit</button>
                                    <button class="btn btn-outline-danger btn-sm w-50"
                                        @onclick="() => AskDelete(book)">Delete</button>
                                </div>
                            }
                            else if (book.IsAvailable)
                            {
                                <a href="/offers/make/@book.TextbookId"
                                    class="btn btn-success btn-sm mt-2 w-100">Make an Offer</a>
                            }
                            else
                            {
                                <span class="badge bg-danger mt-2 w-100 text-center py-2">Sold</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (totalPages > 1)
        {
            <nav class="mt-4 d-flex justify-content-center">
                <ul class="pagination">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">«</button>
                    </li>
                    @for (int p = 1; p <= totalPages; p++)
                    {
                        var pageNum = p;
                        <li class="page-item @(currentPage == pageNum ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                        </li>
                    }
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">»</button>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

@code {
    // State 
    private List<Textbook> allListings = new();
    private List<Textbook> filteredListings = new();
    private List<Textbook> pagedListings = new();

    private string currentUserId = string.Empty;
    private bool isLoading = true;
    private bool showForm = false;
    private int editingId = 0;

    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;

    // Filter state
    private string searchTerm = string.Empty;
    private string filterCondition = string.Empty;
    private decimal? minPrice;
    private decimal? maxPrice;
    private string sortBy = "date";

    // Pagination
    private int currentPage = 1;
    private const int PageSize = 6;
    private int totalPages => (int)Math.Ceiling((double)filteredListings.Count / PageSize);

    // Delete confirmation
    private int confirmDeleteId = 0;
    private string confirmDeleteTitle = string.Empty;

    // Form model
    private TextbookFormModel formModel = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        currentUserId = user?.Id ?? string.Empty;

        await LoadListings();
    }

    private async Task LoadListings()
    {
        isLoading = true;
        allListings = await Db.Textbooks
            .Include(t => t.Seller)
            .OrderByDescending(t => t.DatePosted)
            .ToListAsync();
        ApplyFilters();
        isLoading = false;
    }

    // Filtering & Sorting 
    private void ApplyFilters()
    {
        var query = allListings.AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.ToLower();
            query = query.Where(t =>
                (t.Title ?? "").ToLower().Contains(term) ||
                (t.Author ?? "").ToLower().Contains(term) ||
                (t.ISBN ?? "").ToLower().Contains(term));
        }

        if (!string.IsNullOrEmpty(filterCondition))
            query = query.Where(t => t.Condition == filterCondition);

        if (minPrice.HasValue)
            query = query.Where(t => t.Price >= minPrice.Value);

        if (maxPrice.HasValue)
            query = query.Where(t => t.Price <= maxPrice.Value);

        filteredListings = sortBy switch
        {
            "price_asc"  => query.OrderBy(t => t.Price).ToList(),
            "price_desc" => query.OrderByDescending(t => t.Price).ToList(),
            _            => query.OrderByDescending(t => t.DatePosted).ToList()
        };

        currentPage = 1;
        UpdatePage();
    }

    private void UpdatePage()
    {
        pagedListings = filteredListings
            .Skip((currentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();
    }

    private void GoToPage(int page)
    {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        UpdatePage();
    }

    private void ShowCreateForm()
    {
        formModel = new();
        editingId = 0;
        showForm = true;
        errorMessage = string.Empty;
    }

    private void StartEdit(Textbook book)
    {
        formModel = new TextbookFormModel
        {
            Title    = book.Title,
            Author   = book.Author,
            ISBN     = book.ISBN,
            Condition = book.Condition,
            Price    = book.Price,
            Campus   = book.Campus,
            ImageUrl = book.ImageUrl
        };
        editingId = book.TextbookId;
        showForm = true;
        errorMessage = string.Empty;
    }

    private async Task HandleSave()
    {
        try
        {
            if (editingId == 0)
            {
                // Create
                var textbook = new Textbook
                {
                    Title      = formModel.Title,
                    Author     = formModel.Author,
                    ISBN       = formModel.ISBN,
                    Condition  = formModel.Condition,
                    Price      = formModel.Price,
                    Campus     = formModel.Campus,
                    ImageUrl   = formModel.ImageUrl,
                    SellerId   = currentUserId,
                    IsAvailable = true,
                    DatePosted = DateTime.Now
                };
                Db.Textbooks.Add(textbook);
                successMessage = "Textbook listed successfully!";
            }
            else
            {
                // Update — only allow if owner
                var existing = await Db.Textbooks.FindAsync(editingId);
                if (existing == null || existing.SellerId != currentUserId)
                {
                    errorMessage = "You can only edit your own listings.";
                    return;
                }
                existing.Title     = formModel.Title;
                existing.Author    = formModel.Author;
                existing.ISBN      = formModel.ISBN;
                existing.Condition = formModel.Condition;
                existing.Price     = formModel.Price;
                existing.Campus    = formModel.Campus;
                existing.ImageUrl  = formModel.ImageUrl;
                successMessage = "Listing updated successfully!";
            }

            await Db.SaveChangesAsync();
            CancelForm();
            await LoadListings();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving listing: {ex.Message}";
        }
    }

    private void AskDelete(Textbook book)
    {
        confirmDeleteId = book.TextbookId;
        confirmDeleteTitle = book.Title;
    }

    private async Task ConfirmDelete()
    {
        try
        {
            var book = await Db.Textbooks.FindAsync(confirmDeleteId);
            if (book != null && book.SellerId == currentUserId)
            {
                Db.Textbooks.Remove(book);
                await Db.SaveChangesAsync();
                successMessage = "Listing deleted.";
            }
            else
            {
                errorMessage = "You can only delete your own listings.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting listing: {ex.Message}";
        }
        finally
        {
            confirmDeleteId = 0;
            await LoadListings();
        }
    }

    private void CancelForm()
    {
        showForm = false;
        editingId = 0;
        formModel = new();
    }

    // Form Model 
    public class TextbookFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Title is required")]
        public string Title { get; set; } = string.Empty;
        public string Author { get; set; } = string.Empty;
        public string ISBN { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Condition is required")]
        public string Condition { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Range(1, 100000, ErrorMessage = "Price must be greater than 0")]
        public decimal Price { get; set; }
        public string? Campus { get; set; }
        public string? ImageUrl { get; set; }
    }
}
